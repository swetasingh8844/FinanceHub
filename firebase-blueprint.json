{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the finance system",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user" },
        "email": { "type": "string", "format": "email", "description": "The user's email address" },
        "displayName": { "type": "string", "description": "The user's display name" },
        "role": { "type": "string", "enum": ["admin", "analyst", "viewer"], "description": "The user's role in the system" },
        "status": { "type": "string", "enum": ["active", "inactive"], "description": "The user's status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user was created" }
      },
      "required": ["uid", "email", "role", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction record",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique identifier for the transaction" },
        "amount": { "type": "number", "description": "The amount of the transaction" },
        "type": { "type": "string", "enum": ["income", "expense"], "description": "The type of transaction" },
        "category": { "type": "string", "description": "The category of the transaction (e.g., Food, Rent, Salary)" },
        "date": { "type": "string", "format": "date-time", "description": "The date of the transaction" },
        "description": { "type": "string", "description": "A brief description of the transaction" },
        "createdBy": { "type": "string", "description": "The UID of the user who created the record" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the record was created" }
      },
      "required": ["amount", "type", "category", "date", "createdBy"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial transaction records"
    }
  }
}
